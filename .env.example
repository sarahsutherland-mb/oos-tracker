# Public CSV URL for the Manual Status tab in the "2026 Retail OOS" Google Sheet.
# Get this from: File -> Share -> Publish to web -> Manual Status tab -> CSV -> Publish.
MANUAL_SHEET_URL=https://docs.google.com/spreadsheets/d/e/REPLACE_ME/pub?gid=0&single=true&output=csv

# Optional: Slack incoming webhook URL for weekly change alerts.
# Leave blank to skip Slack notifications.
SLACK_WEBHOOK_URL=
